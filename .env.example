# Data mode: "true" for in-memory mock data, omit or "false" for Supabase
USE_MOCK=true

# Owner email — only this email can access the admin dashboard
OWNER_EMAIL=you@example.com

# Supabase (required when USE_MOCK is not "true")
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public Supabase vars (used by browser client for auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
